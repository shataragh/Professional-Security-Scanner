cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Scan results
/tmp/scan_results/
*.log
*.pkl
nuclei_results.json
sqlmap_results/
cracked_hashes.txt
found_hashes.txt

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Secrets (NEVER commit)
*.key
*.pem
config.yaml
.env
EOF
